# Environment Configuration
GITHUB_TOKEN=your_github_token_here
OPENAI_API_KEY=your_openai_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
MONETIZATION_ENABLED=true
VOICE_COMMANDS_ENABLED=true
AGENT_PROTOCOL_PORT=3001
UI_PORT=3000
LOG_LEVEL=info

# Agent-to-Agent Protocol Configuration
AGENT_ID=toolboxx-agent
AGENT_SECRET=your_agent_secret_here
PROTOCOL_VERSION=1.0.0

# Tool Configuration
TOOLS_ENABLED=code-analysis,testing,deployment,monitoring,security,documentation,collaboration
AUTO_DISCOVERY=true

# Monetization Settings
SUBSCRIPTION_TIER=premium
USAGE_TRACKING=true
REVENUE_ANALYTICS=true